generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model NewsArticle {
  id          Int      @id @default(autoincrement())
  title       String
  excerpt     String
  content     String
  imageUrl    String?
  publishedAt DateTime @default(now())
}
